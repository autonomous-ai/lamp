# LeLamp Runtime — Environment Variables

# --- Original LeLamp (main.py with LiveKit + OpenAI) ---
OPENAI_API_KEY=
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# --- Lumi server.py (FastAPI) ---
# production (default): bind 127.0.0.1, reject non-local requests.
# developer: bind 0.0.0.0, allow all — for local dev/testing only.
#LELAMP_MODE=production
LELAMP_SERVO_PORT=/dev/ttyACM0
LELAMP_LAMP_ID=lumi
LELAMP_SERVO_FPS=30
LELAMP_SERVO_HOLD_S=3.0
LELAMP_HTTP_PORT=5001
LELAMP_CAMERA_INDEX=0
LELAMP_CAMERA_WIDTH=640
LELAMP_CAMERA_HEIGHT=480
#LELAMP_LOG_LEVEL=INFO
#LELAMP_LOG_DIR=/var/log/lelamp
#LELAMP_DEFAULT_USER=unknown
#LELAMP_SENSING_ENABLED=true
#LELAMP_SENSING_INTERVAL=2.0              # Sensing loop poll interval (seconds)
#LUMI_CONFIG_PATH=/root/config/config.json
#LUMI_SENSING_URL=http://127.0.0.1:5000/api/sensing/event
#OPENCLAW_WORKSPACE=/root/.openclaw/workspace

# --- Audio hardware overrides (leave blank to auto-detect) ---
# Run `arecord -l` / `aplay -l` to find card numbers. Format: plughw:<card>,<device>
#LELAMP_AUDIO_INPUT_ALSA=plughw:2,0
#LELAMP_AUDIO_OUTPUT_ALSA=plughw:1,0
#TTS_VOICE=nova                          # alloy, ash, coral, echo, fable, onyx, nova, sage, shimmer
#LELAMP_TTS_SPEED=1.3                    # 1.0=normal, max 4.0
#LELAMP_TTS_INSTRUCTIONS=                # Style/vibe prompt, e.g. "Speak warmly like a caring friend"
# Dedicated mic for ambient noise sensing (SoundPerception). Uses sounddevice device index.
# Run: python3 -c "import sounddevice; print(sounddevice.query_devices())" to list devices.
# If unset, falls back to the same device as LELAMP_AUDIO_INPUT_ALSA.
# Example: 2-mic setup — card 0 (seeed) for sensing, card 1 (USB) for STT
#LELAMP_AUDIO_SENSING_DEVICE=plughw:1,0
#LELAMP_AUDIO_OUTPUT_DEVICE=             # sounddevice index override (auto-derived from AUDIO_OUTPUT_ALSA if unset)

# --- Voice activity detection ---
#LELAMP_VAD_THRESHOLD=500       # RMS threshold; raise if noise triggers false detections
#LELAMP_SOUND_RMS_THRESHOLD=8000  # RMS threshold for "loud noise" sensing event; raise to reduce false triggers
#LELAMP_SILENCE_TIMEOUT=2.5     # Seconds of silence before STT session closes
#LELAMP_SPEECH_HOLDOFF=0.2      # Seconds of speech before STT connects; lower (0.05) for clean mics to avoid losing start of speech

# Secondary VAD filters (run after RMS gate, in order: webrtcvad → Silero)
# Pipeline: RMS → webrtcvad (fast C, ~0.1ms) → Silero ONNX (~20ms) → STT
# Enable both for maximum noise rejection; disable either to reduce CPU or latency.
#LELAMP_WEBRTCVAD_ENABLED=false           # Enable WebRTC VAD pre-filter (pip install webrtcvad)
#LELAMP_WEBRTCVAD_AGGRESSIVENESS=2        # 0 (lenient) to 3 (strict)
#LELAMP_SILERO_ENABLED=true               # Enable Silero ONNX VAD (model bundled in resources/)
#LELAMP_SILERO_THRESHOLD=0.3             # Speech confidence threshold (0.0–1.0); lower = more sensitive
#LELAMP_SILERO_CHUNK_SIZE=512            # Samples per Silero inference call
#LELAMP_WEBRTCVAD_FRAME_MS=30            # Frame size for webrtcvad (10, 20, or 30ms)
#LELAMP_SESSION_COOLDOWN_S=0.3           # Cooldown between STT sessions
#LELAMP_STT_KEEPALIVE=false              # Keep Deepgram WS open between sessions (lower latency, higher cost)

# --- Echo cancellation ---
#LELAMP_ECHO_RMS_FLOOR=200               # RMS must drop below this before re-enabling VAD
#LELAMP_ECHO_GATE_MAX_WAIT_S=1.5         # Max wait for reverb decay after TTS
#LELAMP_ECHO_GATE_WINDOW_S=0.05          # RMS check window (50ms)
#LELAMP_ECHO_SIMILARITY_THRESHOLD=0.55   # Transcript similarity above this = echo, drop it
#LELAMP_ECHO_RELEVANCE_WINDOW_S=15.0     # Only filter echoes within this window after TTS
#LELAMP_MAX_SESSION_DURATION_S=30        # Force-close STT session after this (prevent zombies)

# --- Backchannel: active listening cues during STT ---
# Comma-separated filler words. Empty = feature disabled.
#LELAMP_BACKCHANNEL_FILLERS=Uhm,Ok,Ừ,Hmm
#LELAMP_BACKCHANNEL_STALL_S=8.0           # Partial unchanged for this long → play cue (high default so cue doesn't bleed into mic during speaker-ID capture; 0 = immediate)
#LELAMP_BACKCHANNEL_INTERVAL_S=6.0        # Min seconds between cues
#LELAMP_BACKCHANNEL_VOLUME=0.5            # Volume multiplier (0.0–1.0)

# --- Data layout ---
#LELAMP_POSE_MODEL_PATH=/root/local/models/rtmpose-m.onnx

# --- Camera stream ---
#LELAMP_CAMERA_STREAM_FPS=10             # MJPEG stream frame rate
#LELAMP_CAMERA_STREAM_WIDTH=320          # Stream resize width
#LELAMP_CAMERA_STREAM_JPEG_QUALITY=65    # JPEG compression quality (0-100)

# --- Sensing: Event cooldown ---
#LELAMP_EVENT_COOLDOWN_S=60.0            # Min seconds between events of the same type

# --- Sensing: Sound detection ---
#LELAMP_SOUND_SAMPLE_DURATION_S=0.5      # Sample window for sound level check

# --- Sensing: Light level detection ---
#LELAMP_LIGHT_LEVEL_INTERVAL_S=300.0     # Check every N seconds
#LELAMP_LIGHT_CHANGE_THRESHOLD=50        # Min brightness change (0-255) to trigger event

# --- Sensing: Face detection ---
#LELAMP_USERS_DIR=/root/local/users
#LELAMP_STRANGERS_DIR=/root/local/strangers
#LELAMP_YUNET_CONFIDENCE_THRESHOLD=0.5   # Min confidence for YuNet face detection (lower = catches blur/edge faces)
#LELAMP_FACE_COOLDOWN_S=10.0             # Min seconds between face presence events
#LELAMP_FACE_OWNER_FORGET_S=1800.0       # Re-fire presence after N seconds without seeing owner
#LELAMP_FACE_STRANGER_FORGET_S=1800.0    # Same for strangers (30 min)
#LELAMP_FACE_STRANGER_FLUSH_S=10.0       # Flush stranger snapshots interval
#LELAMP_FACE_AREA_RATIO_THRESHOLD=0.05   # Skip faces smaller than this fraction of frame area (too far / unreliable)

# --- Vision tracking (/servo/track) ---
#LELAMP_TRACKING_DETECT_LOCAL=true       # Use local YOLOv8n for COCO targets (false → force remote YOLOWorld)
#LELAMP_TRACKING_FACE_DETECTOR=true      # Use local YuNet for target='face' (false → fall back to remote YOLOWorld)

# --- Camera snapshot (/camera/snapshot?save=true) ---
# Must be inside one of OpenClaw's allowed media roots (default: state/configDir
# under /root/.openclaw — `media/`, `workspace/`, `canvas/`, `sandboxes/`).
# Outside roots → image tool returns "Local media path is not under an allowed
# directory" and the agent has to cp the file before analyzing.
#LELAMP_SNAPSHOT_DIR=/root/.openclaw/media/lumi-snapshots

# --- Sensing: Motion detection (remote DL backend) ---
#LELAMP_MOTION_ENABLED=true
#LELAMP_MOTION_PER_FACE_ENABLED=false       # per-face action recognition (separate WS session per detected face)
#LELAMP_MOTION_PER_FACE_DEDUP_WINDOW_S=300  # per-action dedup window per face (5 min)
#LELAMP_MOTION_PER_FACE_SESSION_TTL_S=30    # evict face WS session after N seconds without seeing that face
#LELAMP_MOTION_CONFIDENCE_THRESHOLD=0.3
#LELAMP_MOTION_FLUSH_S=10.0
#LELAMP_MOTION_EVENT_COOLDOWN_S=360.0
#LELAMP_MOTION_PERSON_DETECTION_ENABLED=true  # toggle person detection before action recognition (sent to dlbackend)
#LELAMP_MOTION_PERSON_MIN_AREA_RATIO=0.25    # skip persons covering less than 1/4 of frame (sent to dlbackend)
#LELAMP_MOTION_SNAPSHOT_DIR=/tmp/lumi-motion-snapshots
#LELAMP_MOTION_SNAPSHOT_MAX_COUNT=100

# --- Sensing: Emotion detection (remote DL backend) ---
#LELAMP_EMOTION_ENABLED=true
#LELAMP_EMOTION_CONFIDENCE_THRESHOLD=0.5
#LELAMP_EMOTION_FLUSH_S=10.0
#LELAMP_EMOTION_SNAPSHOT_DIR=/tmp/lumi-emotion-snapshots
#LELAMP_EMOTION_SNAPSHOT_MAX_COUNT=100

# --- DL backend connection ---
#DL_BACKEND_URL=                         # Base WS URL, e.g. wss://<pod>-8888.proxy.runpod.net/lelamp
#DL_API_KEY=                             # Shared secret for X-API-Key auth
#DL_MOTION_ENDPOINT=/api/dl/action-analysis/ws    # Appended to DL_BACKEND_URL
#DL_EMOTION_ENDPOINT=/api/dl/emotion-analysis/ws  # Appended to DL_BACKEND_URL
#DL_SPEAKER_ENDPOINT=/api/dl/audio-recognizer/embed  # Appended to DL_BACKEND_URL
#LELAMP_DL_HEARTBEAT_INTERVAL_S=60.0     # WebSocket heartbeat interval (seconds)

# --- DL backend encryption (RSA + AES-256-GCM) ---
#LELAMP_DL_ENCRYPTION=false              # Enable client-side encryption for DL backend
#LELAMP_DL_ENCRYPTION_REQUIRED=false     # Fail if encryption setup fails (no plaintext fallback)
#DL_PUBLIC_KEY_PEM=                      # RSA public key PEM (if set, skips fetching from LB)

# --- Sensing: Speaker recognition (voice embedding via dlbackend) ---
#LELAMP_SPEAKER_RECOGNITION_ENABLED=true
#LELAMP_SPEAKER_MIN_AUDIO_S=0.8          # Min audio duration (seconds) for speaker embedding
#SPEAKER_MATCH_THRESHOLD=0.7             # Cosine similarity threshold for speaker match (0.0-1.0)
#SPEAKER_ENROLL_CONSISTENCY_THRESHOLD=0.7 # Min consistency between enrollment samples
#SPEAKER_EMBEDDING_API_TIMEOUT_S=15      # Timeout for embedding API call (seconds)
#LELAMP_UNKNOWN_AUDIO_DIR=/tmp/lumi-unknown-voice  # Where unknown speaker audio is saved
#LELAMP_VOICE_STRANGERS_DIR=/root/local/voice_strangers  # Persisted stranger centroid state (embeds/labels/counter .npy)
# All thresholds below are SCALED cosine in [0, 1] (`(raw + 1) / 2`), same
# unit as SPEAKER_MATCH_THRESHOLD. Ordering: CLUSTER_MERGE < STRANGER_MATCH
# < MATCH = CONSISTENCY. Defaults sit just below the EER band so same-
# speaker-different-distance doesn't fragment into multiple clusters.
#LELAMP_VOICE_STRANGER_MATCH_THRESHOLD=0.675  # Scaled cosine to reuse same voice_<N> for new unknown utterance
#LELAMP_MAX_VOICE_STRANGERS=50                # Cap on tracked stranger clusters (oldest evicted first)
#LELAMP_CLUSTER_MERGE_THRESHOLD=0.625         # Scaled cosine to auto-merge fragmented clusters on enroll (looser; consistency filter catches false merges)
#LELAMP_SPEAKER_CHUNK_SECONDS=3.0             # Chunk window for /embed; longer = smoother per-chunk emb but fewer votes
#LELAMP_ENROLL_NUDGE_COOLDOWN_S=1800          # Per-cluster cooldown for enroll nudge (seconds, default 30 min)

# --- Sensing: Pose-based motion detection (RTMPose) ---
#LELAMP_POSE_MOTION_ENABLED=true
#LELAMP_POSE_MOTION_ANGLE_THRESHOLD=30.0  # Min arm joint angle change (degrees)

# --- Sensing: Snapshot storage ---
#LELAMP_SNAPSHOT_TMP_DIR=/tmp/lumi-sensing-snapshots
#LELAMP_SNAPSHOT_TMP_MAX_COUNT=50
#LELAMP_SNAPSHOT_PERSIST_DIR=/var/lib/lelamp/snapshots
#LELAMP_SNAPSHOT_PERSIST_TTL_S=259200     # 72 hours
#LELAMP_SNAPSHOT_PERSIST_MAX_BYTES=52428800  # 50 MB

# --- Presence: Auto light on/off ---
#LELAMP_IDLE_TIMEOUT_S=300               # Seconds before dim
#LELAMP_AWAY_TIMEOUT_S=900               # Seconds before off
#LELAMP_IDLE_BRIGHTNESS=0.20

# --- CPU / thread tuning (important for Raspberry Pi) ---
OMP_NUM_THREADS=1               # Limit OpenMP threads used by onnxruntime/numpy — prevents thread pool from spinning all 4 Pi cores
OPENBLAS_NUM_THREADS=1          # Same for OpenBLAS (used by numpy/scipy)
