{
  "id": "auto-wechat-openclaw-channel",
  "name": "WeChat Access via Gewechat",
  "description": "OpenClaw 微信通路插件，通过 Gewechat 作为适配层接入。",
  "version": "0.1.0",
  "channels": ["auto-wechat-openclaw-channel"],
  "configSchema": {
    "type": "object",
    "properties": {
      "enabled": {
        "type": "boolean",
        "description": "是否启用渠道"
      },
      "gewechatBaseUrl": {
        "type": "string",
        "description": "Gewechat 服务基础 URL，例如 http://localhost:2531"
      },
      "webhookPort": {
        "type": "number",
        "description": "适配器 webhook HTTP 端口，例如 3002"
      },
      "botMention": {
        "type": "string",
        "description": "触发回复的关键字，例如 @bot",
        "default": "@bot"
      },
      "accounts": {
        "type": "object",
        "description": "多账号配置",
        "additionalProperties": true
      }
    }
  }
}

