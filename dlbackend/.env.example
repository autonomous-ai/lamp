DL_API_KEY=changeme
DL_BACKEND_URL=http://localhost:8001

# --- Load balancer ---
LB__BACKENDS=http://127.0.0.1:8888         # comma-separated nginx endpoints
# LB__HOST=0.0.0.0                           # listen host (default: 0.0.0.0)
# LB__PORT=7999                              # listen port (default: 7999)
# LB__INTERNAL_PREFIX=/_internal             # prefix prepended to all forwarded paths

# --- Encryption (RSA + AES-256-GCM) ---
# CRYPTO__ENABLED=true                       # enable hybrid encryption at LB layer
# CRYPTO__KEY_DIR=/root/local/keys           # persist RSA key pair (omit for in-memory)
# CRYPTO__KEY_SIZE=2048                      # RSA key size
# CRYPTO__REQUIRE_ENCRYPTION=false           # reject plaintext requests when true

# --- Action recognition ---
# ACTION__ENABLED=true
# ACTION__MODEL=x3d                        # videomae | uniformerv2 | x3d
# ACTION__CKPT_PATH=/path/to/model.onnx
# ACTION__CONFIDENCE_THRESHOLD=0.3         # override model default
# ACTION__MAX_FRAMES=16                    # override model default
# ACTION__FRAME_INTERVAL=1.0              # override model default
# ACTION__W=256                            # override model default
# ACTION__H=256                            # override model default

# --- Facial emotion recognition (FER) ---
# FER__ENABLED=true
# FER__MODEL=posterv2                      # posterv2 | emonet_8 | emonet_5
# FER__CKPT_PATH=/path/to/posterv2_7cls.onnx
# FER__CONFIDENCE_THRESHOLD=0.5            # override model default
# FER__FRAME_INTERVAL=1.0                 # override model default

# --- Speech emotion recognition (SER) ---
# SER__ENABLED=true
# SER__MODEL=emotion2vec                   # emotion2vec
# SER__CKPT_PATH=/path/to/emotion2vec.onnx
# SER__LABELS_PATH=/path/to/labels.txt

# --- Pose estimation ---
POSE__ENABLED=true
POSE__MODEL=rtmpose                       # rtmpose
# POSE__CKPT_PATH=/path/to/rtmpose-m.onnx
# POSE__CONFIDENCE_THRESHOLD_2D=0.3       # min per-keypoint confidence for 3D lifting
# POSE__MIN_VALID_KEYPOINTS=5             # need this many confident keypoints to lift
POSE__ERGO_ASSESSOR=rula                  # rula | (omit to disable ergonomic assessment)
# POSE__ERGO_CONFIDENCE_THRESHOLD=0.3     # min joint confidence for ergo assessment
# POSE__LIFTER_3D=tcpformer               # tcpformer | (omit/leave empty to disable 3D)
# POSE__LIFTER_3D_CKPT_PATH=/path/to/tcpformer_h36m_243.onnx
# POSE__LIFTER_3D_FRAME_W=1920
# POSE__LIFTER_3D_FRAME_H=1080

# --- Person detector (used by action recognition) ---
# PERSON_DETECTOR__ENABLED=false
# PERSON_DETECTOR__MODEL=yolo
# PERSON_DETECTOR__MODEL_NAME=yolo12x.pt
# PERSON_DETECTOR__CONFIDENCE_THRESHOLD=0.4
# PERSON_DETECTOR__BBOX_EXPAND_SCALE=2.0
# PERSON_DETECTOR__MIN_AREA_RATIO=0.25

# --- Object detection (zero-shot) ---
# Each detector has its own enable flag. Multiple can run simultaneously.
# Endpoints: POST /api/dl/{name} (flat list), POST /api/dl/object-detect/{name} (wrapped)
#            WS   /api/dl/object-detection/{name}/ws
#
# YOLO-World (ultralytics)
# OBJECT_DETECTOR__YOLO_WORLD__ENABLED=false
# OBJECT_DETECTOR__YOLO_WORLD__MODEL_PATH=yolov8x-worldv2.pt
# OBJECT_DETECTOR__YOLO_WORLD__CLASSES_PATH=/path/to/classes.txt
# OBJECT_DETECTOR__YOLO_WORLD__THRESHOLD=0.25
#
# YOLO-E (ultralytics)
# OBJECT_DETECTOR__YOLOE__ENABLED=false
# OBJECT_DETECTOR__YOLOE__MODEL_PATH=yoloe-26x-seg.pt
# OBJECT_DETECTOR__YOLOE__THRESHOLD=0.25
#
# OWLv2 (HuggingFace transformers)
# OBJECT_DETECTOR__OWLV2__ENABLED=false
# OBJECT_DETECTOR__OWLV2__MODEL_PATH=google/owlv2-large-patch14-ensemble
# OBJECT_DETECTOR__OWLV2__THRESHOLD=0.1
#
# Grounding DINO (HuggingFace transformers)
# OBJECT_DETECTOR__GROUNDING_DINO__ENABLED=false
# OBJECT_DETECTOR__GROUNDING_DINO__MODEL_PATH=IDEA-Research/grounding-dino-tiny
# OBJECT_DETECTOR__GROUNDING_DINO__THRESHOLD=0.25

# --- Audio embedder ---
# AUDIO_EMBEDDER__ENABLED=false
# AUDIO_EMBEDDER__MODEL=resnet34              # resnet34 | ecapa-tdnn1024 | campplus
# AUDIO_EMBEDDER__MODEL_PATH=/path/to/model.onnx
#
# Preprocessing pipeline (all enabled by default):
# AUDIO_EMBEDDER__PROCESSOR__TARGET_SAMPLE_RATE=16000
# AUDIO_EMBEDDER__PROCESSOR__ENABLE_RESAMPLE=true
# AUDIO_EMBEDDER__PROCESSOR__ENABLE_HIGH_PASS=true
# AUDIO_EMBEDDER__PROCESSOR__HIGH_PASS_CUTOFF_HZ=80.0
# AUDIO_EMBEDDER__PROCESSOR__ENABLE_NOISE_REDUCE=true
# AUDIO_EMBEDDER__PROCESSOR__NOISE_REDUCE_STATIONARY=false
# AUDIO_EMBEDDER__PROCESSOR__ENABLE_VAD=true
# AUDIO_EMBEDDER__PROCESSOR__VAD_MIN_DURATION_SEC=0.5
# AUDIO_EMBEDDER__PROCESSOR__VAD_MIN_VOICE_RATIO=0.4
# AUDIO_EMBEDDER__PROCESSOR__ENABLE_RMS_NORMALIZE=true
# AUDIO_EMBEDDER__PROCESSOR__RMS_TARGET=0.1
