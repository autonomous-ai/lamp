# Twitch app credentials from https://dev.twitch.tv/console/apps
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# Shared secret for signing webhook payloads. 10-100 chars. Random.
# Must match between subscribe step and the running webhook server.
TWITCH_WEBHOOK_SECRET=

# OAuth USER access token of the bot account (not an app token).
# Required scope: user:read:chat
# Additional: either channel:bot from broadcaster, OR bot is a moderator.
TWITCH_BOT_USER_TOKEN=

# Webhook server
PORT=8080
